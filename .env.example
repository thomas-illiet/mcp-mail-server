MCP_PORT=8000
LOG_LEVEL=INFO
EMAIL_MOCK_MODE=false
MCP_BEARER_TOKEN=

SMTP_HOST=maildev
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=MCP Server <mcp@example.local>
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

# Empty value allows every recipient domain.
# Example: ^(example\.com|.+\.example\.org)$
ALLOWED_RECIPIENT_DOMAIN_REGEX=

MAILDEV_SMTP_PORT=1025
MAILDEV_WEB_PORT=1080
MAILDEV_IP=0.0.0.0
MAILDEV_WEB_IP=0.0.0.0
